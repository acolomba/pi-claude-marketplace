{
  "author": {
    "name": "Alessandro Colomba"
  },
  "description": "Access Claude plugin marketplaces from Pi.",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@mariozechner/pi-coding-agent": "^0.70.6",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^10.2.1",
    "eslint-plugin-import-x": "^4.16.2",
    "globals": "^17.5.0",
    "prettier": "^3.6.2",
    "tsx": "^4.21.0",
    "typebox": "^1.1.34",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "claude",
    "marketplace"
  ],
  "license": "MIT",
  "name": "pi-claude-marketplace",
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "typebox": "*"
  },
  "pi": {
    "extensions": [
      "./extensions/claude-marketplace/index.ts"
    ]
  },
  "scripts": {
    "check": "npm run typecheck && npm run lint && npm run format:check && npm test",
    "test": "node --import tsx --test \"tests/*.test.ts\" \"tests/{agent,commands,helpers,location,marketplace,mcp,plugin,presentation,resource,state,transaction}/**/*.test.ts\"",
    "test:integration": "node --import tsx --test \"tests/integration/**/*.test.ts\"",
    "format": "prettier --write \"**/*.{js,json,ts}\"",
    "format:check": "prettier --check \"**/*.{js,json,ts}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "version": "0.1.0"
}
