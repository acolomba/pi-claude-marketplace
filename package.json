{
  "author": {
    "name": "Alessandro Colomba"
  },
  "description": "Access Claude plugin marketplaces from Pi.",
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.73.1",
    "prettier": "^3.6.2",
    "typebox": "^1.1.38",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "claude",
    "marketplace"
  ],
  "license": "MIT",
  "name": "pi-claude-marketplace",
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "typebox": "*"
  },
  "pi": {
    "extensions": [
      "./extensions/claude-marketplace.ts"
    ]
  },
  "scripts": {
    "check": "npm run typecheck && npm run format:check",
    "format": "prettier --write \"**/*.{json,ts}\"",
    "format:check": "prettier --check \"**/*.{json,ts}\"",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "version": "0.1.0"
}
